# Telegram Bot Configuration
# Copy this file to .env.bot.secret and fill in your values

# Telegram bot token (get from @BotFather)
BOT_TOKEN=your-bot-token-from-botfather

# LMS API configuration
LMS_API_BASE_URL=http://localhost:42002
LMS_API_KEY=your-lms-api-key

# LLM API configuration (Qwen Code)
LLM_API_KEY=your-qwen-api-key
LLM_API_BASE_URL=http://localhost:42005/v1
LLM_API_MODEL=coder-model
