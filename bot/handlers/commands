"""Command handlers for the bot - no Telegram dependencies."""

import re
from typing import Optional
from services.lms_client import LMSClient
from services.llm_client import LLMClient

lms_client = LMSClient()
llm_client = LLMClient()


def start() -> str:
    return "🤖 **Welcome to SE Toolkit Lab Bot!**\n\nI can help you track progress in the Software Engineering Toolkit labs.\n\n**Try asking me:**\n• What labs are available?\n• Show me scores for lab 4\n• Which lab has the lowest pass rate?\n\nUse /help to see all commands."


def help() -> str:
    return """📋 **Available Commands**

**Slash Commands:**
/start - Welcome message
/help - Show this help
/health - Check backend status
/labs - List all labs
/scores <lab> - Show pass rates

**Natural Language Queries:**
• "what labs are available?"
• "show me scores for lab 4"
• "which lab has the lowest pass rate?"

💡 Just type your question naturally!"""


def health() -> str:
    is_healthy, message = lms_client.check_health()
    return message


def labs() -> str:
    try:
        labs_data = lms_client.get_labs()
        if not labs_data:
            return "📚 No labs found."

        lab_names = {
            1: "Products, Architecture & Roles",
            2: "Run, Fix, and Deploy",
            3: "Backend API",
            4: "Testing, Front-end, and AI Agents",
            5: "Data Pipeline and Analytics",
            6: "Build Your Own Agent",
        }

        result = "📚 **Available Labs**\n\n"
        for lab in labs_data[:6]:
            lab_id = lab.get("id", 0)
            if isinstance(lab_id, str) and lab_id.isdigit():
                lab_id = int(lab_id)
            name = lab_names.get(lab_id, f"Lab {lab_id}")
            result += f"**Lab {lab_id:02d}** — {name}\n"
        return result.strip()
    except Exception as e:
        return f"❌ Error: {str(e)}"


def scores(lab_name: str = "") -> str:
    if not lab_name:
        return "❌ Please specify a lab, e.g., /scores lab-04"

    if not lab_name.startswith("lab-"):
        lab_name = f"lab-{lab_name.zfill(2)}" if lab_name.isdigit() else lab_name

    try:
        pass_rates = lms_client.get_pass_rates(lab_name)
        if not pass_rates:
            return f"📊 No data for {lab_name}."

        result = f"📈 **Pass Rates for {lab_name.upper()}**\n\n"
        tasks = pass_rates.get("tasks", [])

        for task in tasks:
            task_name = task.get("name") or task.get("task") or "Task"
            pass_rate = task.get("pass_rate") or task.get("avg_score") or 0
            attempts = task.get("attempts", 0)
            result += f"• **{task_name}**: {pass_rate:.1f}% ({attempts} attempts)\n"
        return result.strip()
    except Exception as e:
        return f"❌ {str(e)}"


def process_natural_query(query: str) -> str:
    try:
        return llm_client.process_message(query)
    except Exception as e:
        return f"❌ Error: {str(e)}"


def unknown() -> str:
    return "❓ Unknown command. Use /help to see available commands."


